APP_NAME=NetSentinel AI
APP_ENV=development
APP_DEBUG=true
API_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000

DATABASE_URL=sqlite:///./network_anomaly.db
CELERY_BROKER_URL=memory://
CELERY_RESULT_BACKEND=cache+memory://
CELERY_TASK_ALWAYS_EAGER=true

JWT_SECRET_KEY=change_me_super_secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

ANOMALY_ALERT_THRESHOLD=0.75
ALERT_EMAIL_FROM=noreply@netsentinel.local
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=false

MODEL_ARTIFACT_DIR=backend/app/ml/artifacts
